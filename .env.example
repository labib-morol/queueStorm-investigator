# QueueStorm Investigator — environment variables (names only, no real secrets)

# Groq API key for LLM refinement. OPTIONAL: if unset, the service falls back
# to its deterministic rule-based engine and still works fully.
GROQ_API_KEY=

# Groq model used for analysis.
MODEL_NAME=llama-3.3-70b-versatile

# Port the service binds to (bound to 0.0.0.0).
PORT=8000

# Set to 0 to disable Groq entirely and run rule-based only (optional).
USE_GROQ=1

# Max seconds to wait on Groq before falling back to rules (optional).
GROQ_TIMEOUT_SECONDS=4.0
